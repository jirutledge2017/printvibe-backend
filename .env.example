# ── StippleCrown.com environment ─────────────────────────────────
# Copy this file to `.env` and fill in your real keys.

# Printful API token — get yours at https://www.printful.com/dashboard/store/api
PRINTFUL_TOKEN=your_printful_token_here

# Stripe — get these from https://dashboard.stripe.com/apikeys
# SECRET key stays on the server. PUBLISHABLE key is safe to expose to the browser.
STRIPE_SECRET_KEY=sk_live_or_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_publishable_key_here

# Optional — powers the StippleCrown Concierge AI chat.
# Without it, the concierge still works using built-in answers.
ANTHROPIC_API_KEY=

# Server port (default: 3001)
PORT=3001
